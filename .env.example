# Backend
GUARDED_ALPHA_ENV=development
GUARDED_ALPHA_DATA_DIR=data
GUARDED_ALPHA_KILL_SWITCH_PATH=data/KILL_SWITCH

# Live trading is disabled by default. Set to true only after dry-run checks pass.
LIVE_TRADING_ENABLED=false

# TWAK / on-chain execution
TWAK_BIN=twak
COMPETITION_CONTRACT=0x212c61b9b72c95d95bf29cf032f5e5635629aed5
# TWAK accepts these names. TW_ACCESS_ID / TW_HMAC_SECRET are also mapped as aliases.
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=
# Required for registration/live signing unless saved in TWAK keychain.
TWAK_WALLET_PASSWORD=
# Optional read fallback used only to verify BSC stable balances if TWAK omits them.
BSC_RPC_URL=https://bsc-dataseed.binance.org/

# CMC CLI
CMC_BIN=cmc
CMC_USE_FIXTURES=true
PORTFOLIO_USE_FIXTURES=true
TRADE_SOURCE_SYMBOL=USDC
# Use the full fixed competition token list from apps/agent/src/guarded_alpha/competition.py.
SCAN_FULL_COMPETITION_UNIVERSE=false
# Manual scan universe when SCAN_FULL_COMPETITION_UNIVERSE=false.
ELIGIBLE_SYMBOLS=AAVE,ADA,APE,ASTER,AVAX,BCH,CAKE,DOGE,DOT,ETH,FDUSD,FET,FIL,FLOKI,INJ,LINK,LTC,PENDLE,SFP,TWT,UNI,USDC,USDT,XRP,ZRO

# Mandate
MAX_DRAWDOWN_PCT=15
DAILY_LOSS_LIMIT_PCT=4
MAX_TRADE_PCT=20
MAX_POSITION_PCT=70
MAX_SLIPPAGE_BPS=80
# Kept for compatibility; execution now uses MIN_CASH_BUFFER_USD instead of a hard stable pct.
MIN_STABLE_RESERVE_PCT=0
MIN_CASH_BUFFER_USD=3
MIN_EXPECTED_EDGE_BPS=50
MIN_SIGNAL_SCORE=0.20
MIN_DAILY_TRADE_USD=5
MAX_DAILY_TRADES=8
SCHEDULER_INTERVAL_SECONDS=900
STRATEGY_WEIGHTS=momentum:0.25,mean_reversion:0.15,liquidity:0.15,sentiment:0.20,regime:0.10,route:0.10,rebalance:0.05

# Optional BNB Agent SDK identity proof
ENABLE_BNB_IDENTITY=false
BNBAGENT_NETWORK=bsc-testnet

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_POLL_MS=15000
